---
interface Props {
  title?: string;
  description?: string;
}

const { title, description = 'Distilld — Regulatory alerts for Canadian businesses.' } = Astro.props;
const pageTitle = title ? `${title} — Distilld` : 'Distilld';
---
<!DOCTYPE html>
<html class="light" lang="en">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "surface-tint": "#405f91",
            "error-container": "#ffdad6",
            "tertiary-container": "#4f1c02",
            "primary-container": "#002b5b",
            "surface-dim": "#d9dadb",
            "on-error": "#ffffff",
            "inverse-primary": "#a9c7ff",
            "on-secondary-container": "#4d607e",
            "primary-fixed": "#d6e3ff",
            "on-surface": "#191c1d",
            "on-secondary-fixed-variant": "#344765",
            "background": "#f8f9fa",
            "on-tertiary-fixed": "#360f00",
            "surface-container-lowest": "#ffffff",
            "secondary-fixed": "#d5e3ff",
            "tertiary-fixed": "#ffdbcd",
            "surface-container-highest": "#e1e3e4",
            "secondary": "#4c5f7d",
            "inverse-on-surface": "#f0f1f2",
            "on-secondary": "#ffffff",
            "surface-bright": "#f8f9fa",
            "inverse-surface": "#2e3132",
            "outline-variant": "#c4c6d0",
            "on-primary-fixed-variant": "#264778",
            "surface": "#f8f9fa",
            "secondary-container": "#c7dbff",
            "on-tertiary-container": "#cd805d",
            "primary-fixed-dim": "#a9c7ff",
            "on-primary-container": "#7594ca",
            "surface-variant": "#e1e3e4",
            "on-secondary-fixed": "#051c37",
            "on-primary": "#ffffff",
            "surface-container": "#edeeef",
            "primary": "#001736",
            "on-surface-variant": "#43474f",
            "surface-container-high": "#e7e8e9",
            "tertiary-fixed-dim": "#ffb596",
            "on-tertiary-fixed-variant": "#713619",
            "surface-container-low": "#f3f4f5",
            "secondary-fixed-dim": "#b4c7ea",
            "on-primary-fixed": "#001b3d",
            "tertiary": "#2f0c00",
            "outline": "#747780",
            "error": "#ba1a1a",
            "on-background": "#191c1d",
            "on-error-container": "#93000a",
            "on-tertiary": "#ffffff"
          },
          fontFamily: {
            "headline": ["Manrope"],
            "body": ["Inter"],
            "label": ["Inter"]
          },
          borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
        },
      },
    }
  </script>
  <style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      display: inline-block;
      line-height: 1;
    }
    .bg-glass {
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }
    .primary-gradient {
      background: linear-gradient(135deg, #001736 0%, #002b5b 100%);
    }
    .ios-shadow {
      box-shadow: 0 12px 32px rgba(0, 23, 54, 0.06);
    }
  </style>
</head>
<body class="bg-surface font-body text-on-surface antialiased">

  <nav class="fixed top-0 w-full z-50 bg-slate-50/80 dark:bg-slate-950/80 backdrop-blur-xl">
    <div class="flex justify-between items-center px-6 py-4 max-w-7xl mx-auto">
      <a href="/" class="text-2xl font-black text-blue-900 dark:text-blue-100 tracking-tighter font-headline">Distilld</a>
      <div class="flex items-center gap-6">
        <div class="hidden md:flex gap-8 font-manrope text-sm font-medium tracking-tight">
          <a class="text-slate-500 dark:text-slate-400 hover:bg-slate-200/50 dark:hover:bg-slate-800/50 transition-colors px-3 py-1 rounded-lg" href="#">App</a>
          <a class="text-slate-500 dark:text-slate-400 hover:bg-slate-200/50 dark:hover:bg-slate-800/50 transition-colors px-3 py-1 rounded-lg" href="#">Documentation</a>
        </div>
        <button class="p-2 rounded-full hover:bg-slate-200/50 dark:hover:bg-slate-800/50 transition-colors">
          <span class="material-symbols-outlined text-blue-900 dark:text-blue-100">public</span>
        </button>
      </div>
    </div>
  </nav>

  <slot />

  <footer class="w-full py-12 border-t border-slate-200/20 dark:border-slate-800/20 bg-slate-50 dark:bg-slate-950">
    <div class="flex flex-col md:flex-row justify-between items-center px-8 gap-4 max-w-7xl mx-auto">
      <div class="text-lg font-bold text-blue-900 dark:text-blue-50 font-headline">Distilld</div>
      <div class="flex flex-wrap justify-center gap-8 font-inter text-xs text-slate-500 dark:text-slate-400">
        <a class="hover:text-blue-900 dark:hover:text-blue-100 transition-colors opacity-80 hover:opacity-100" href="/terms">Terms of Service</a>
        <a class="hover:text-blue-900 dark:hover:text-blue-100 transition-colors opacity-80 hover:opacity-100" href="/privacy">Privacy Policy</a>
        <a class="hover:text-blue-900 dark:hover:text-blue-100 transition-colors opacity-80 hover:opacity-100" href="#">Contact</a>
      </div>
      <div class="font-inter text-xs text-slate-500 dark:text-slate-400">
        &copy; 2026 Distilld. Built for the Canadian Jurist.
      </div>
    </div>
  </footer>

</body>
</html>
