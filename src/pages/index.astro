---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="min-h-screen pt-32 pb-20 px-6 flex flex-col items-center justify-center">

    <div class="w-full max-w-xl text-center mb-12">
      <h1 class="font-headline text-5xl md:text-6xl font-extrabold tracking-tighter text-primary mb-4">
        Canadian Law, Monitored & <span class="text-on-primary-container">Distilld.</span>
      </h1>
      <p class="text-on-surface-variant text-lg max-w-md mx-auto">
        Stay ahead of Canadian regulatory changes, automatically.
      </p>
    </div>

    <ul class="w-full max-w-md mb-8 space-y-3">
      <li class="flex items-center gap-3 text-on-surface-variant">
        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">rocket_launch</span>
        <span><span class="font-semibold text-on-surface">Early access</span> — Be first in line when Distilld launches</span>
      </li>
      <li class="flex items-center gap-3 text-on-surface-variant">
        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">sell</span>
        <span><span class="font-semibold text-on-surface">Founding pricing</span> — Beta members lock in a special rate</span>
      </li>
      <li class="flex items-center gap-3 text-on-surface-variant">
        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">rate_review</span>
        <span><span class="font-semibold text-on-surface">Shape the product</span> — Your feedback directly influences what we build</span>
      </li>
    </ul>

    <div class="w-full max-w-md bg-surface-container-lowest p-8 md:p-10 rounded-xl ios-shadow">
      <form action="#" class="space-y-8" method="POST">
        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2" for="email">Email</label>
          <input class="w-full bg-surface-container-highest border-none rounded-lg py-4 px-4 text-primary font-medium focus:ring-0 focus:border-b-2 focus:border-primary transition-all placeholder:text-outline/50" id="email" name="email" placeholder="name@firm.ca" type="email" required/>
        </div>
        <button class="w-full primary-gradient text-white font-headline font-bold py-4 rounded-full text-lg shadow-lg active:scale-95 transition-transform" type="submit">
          Join the Beta
        </button>
      </form>
      <div class="mt-10 flex items-center justify-center gap-2 text-on-surface-variant">
        <span class="material-symbols-outlined text-error" style="font-variation-settings: 'FILL' 1;">eco</span>
        <span class="text-sm font-medium">Tailored for the Canadian Legal Landscape</span>
      </div>
    </div>

    <div class="fixed top-1/4 -left-20 w-64 h-64 bg-primary-container/5 rounded-full blur-3xl -z-10"></div>
    <div class="fixed bottom-1/4 -right-20 w-96 h-96 bg-secondary-container/10 rounded-full blur-3xl -z-10"></div>

  </main>
</Layout>
