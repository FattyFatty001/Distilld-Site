---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="min-h-screen pt-24 pb-12 px-6 flex flex-col items-center justify-center">

    <div class="w-full max-w-xl text-center mb-8">
      <h1 class="font-headline text-5xl md:text-6xl font-extrabold tracking-tighter text-primary mb-4">
        Canadian Law, Monitored & <span class="text-on-primary-container">Distilld.</span>
      </h1>
      <p class="text-slate-500 text-lg max-w-md mx-auto">
        Helping businesses stay ahead of Canadian regulatory changes.
      </p>
    </div>

    <p class="w-full max-w-md mb-6 text-slate-600 text-base leading-relaxed">
      We're starting close to home — Distilld is being built for Canadian businesses, we're looking for a small and deliberate group of early users who can help shape what it becomes.
    </p>

    <ul class="w-full max-w-md mb-6 space-y-2">
      <li class="flex items-start gap-3">
        <span class="material-symbols-outlined text-blue-900 mt-0.5 shrink-0" style="font-variation-settings: 'FILL' 1; font-size: 20px;">bolt</span>
        <span class="text-slate-700 text-sm leading-snug"><span class="font-semibold text-slate-800">Early access</span> — Be first in line when Distilld launches.</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="material-symbols-outlined text-blue-900 mt-0.5 shrink-0" style="font-variation-settings: 'FILL' 1; font-size: 20px;">tune</span>
        <span class="text-slate-700 text-sm leading-snug"><span class="font-semibold text-slate-800">Shape the product</span> — Your feedback directly influences what we build.</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="material-symbols-outlined text-blue-900 mt-0.5 shrink-0" style="font-variation-settings: 'FILL' 1; font-size: 20px;">workspace_premium</span>
        <span class="text-slate-700 text-sm leading-snug"><span class="font-semibold text-slate-800">Founding member</span> — Join a small, deliberate group building something that matters for the Canadian legal community.</span>
      </li>
    </ul>

    <form action="#" class="w-full max-w-md space-y-3" method="POST">
      <div>
        <label class="block text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2" for="email">Email</label>
        <input class="w-full bg-white border-none rounded-xl py-4 px-4 text-blue-900 font-medium focus:ring-0 ios-shadow transition-all placeholder:text-slate-400" id="email" name="email" placeholder="name@firm.ca" type="email" required/>
      </div>
      <button class="w-full primary-gradient text-white font-headline font-bold py-4 rounded-full text-lg shadow-lg active:scale-95 transition-transform" type="submit">
        Join the Beta
      </button>
      <div class="pt-2 flex items-center justify-center gap-2 text-slate-500">
        <span class="material-symbols-outlined text-blue-900" style="font-variation-settings: 'FILL' 1;">eco</span>
        <span class="text-sm font-medium">Tailored for the Canadian Legal Landscape</span>
      </div>
    </form>

    <div class="fixed top-1/4 -left-20 w-64 h-64 bg-primary-container/5 rounded-full blur-3xl -z-10"></div>
    <div class="fixed bottom-1/4 -right-20 w-96 h-96 bg-secondary-container/10 rounded-full blur-3xl -z-10"></div>

  </main>
</Layout>
