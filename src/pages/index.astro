---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="flex-1 flex flex-col">
    <div class="h-16 shrink-0"></div>
    <div class="my-auto w-full max-w-7xl mx-auto px-6 py-8">
      <div class="max-w-[620px] ml-16">

        <div class="mb-16">
          <h1 class="font-headline text-5xl md:text-6xl font-extrabold tracking-tighter text-primary mb-4">
            Canadian Law, Monitored & <span class="text-on-primary-container">Distilld.</span>
          </h1>
          <p class="text-slate-500 text-lg">
            Helping businesses stay ahead of Canadian regulatory changes.
          </p>
        </div>

        <p class="mb-20 text-slate-600 text-lg leading-relaxed">
          We're starting close to home. Distilld is being built for Canadian businesses and we're looking for early users who can help shape what it becomes.
        </p>

        <!-- Success message — shown after submission -->
        <div id="success-message" style="display:none;" class="mb-3 text-sm font-medium text-center rounded-lg py-2 px-3 text-green-700 bg-green-50">
          You're on the list! We'll be in touch.
        </div>

        <!-- Hidden iframe: form posts here so the page never navigates away -->
        <iframe name="brevo-target" style="display:none;" aria-hidden="true"></iframe>

        <form
          id="sib-form"
          action="https://58642e8d.sibforms.com/serve/MUIFAD0DU6EwvKO90roWquyc652EGh6hd2zZNHpClXoABqO2MpP7Z69posBzx-Zg-9JimEoxuB5RLzOafkJmusZ1BGrYAdlxWEDCmP9EhPkMlyayJVgFPwaQG87-_tXqUQPzGTXiC_Ppna_VTW7JD9iVZvv14yOgIKfij4n8ZaCnnHwUP4_IQXF6oH_Ux53AMbce4BDaVg-_tdCQSg=="
          method="POST"
          target="brevo-target"
          class="w-full space-y-3"
        >
          <div>
            <label class="block text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2" for="EMAIL">Email</label>
            <input class="w-full bg-white border-none rounded-xl py-4 px-4 text-blue-900 font-medium focus:ring-0 ios-shadow transition-all placeholder:text-slate-400" id="EMAIL" name="EMAIL" placeholder="name@firm.ca" type="email" autocomplete="email" required />
          </div>
          <button id="signup-btn" class="w-full primary-gradient text-white font-headline font-bold py-4 rounded-full text-lg shadow-lg active:scale-95 transition-transform" type="submit">
            Join the Beta
          </button>
          <div class="pt-2 flex items-center gap-2 text-slate-500">
            <span class="material-symbols-outlined text-blue-900" style="font-variation-settings: 'FILL' 1;">eco</span>
            <span class="text-sm font-medium">Tailored for the Canadian Legal Landscape</span>
          </div>

          <!-- Brevo required fields -->
          <input type="text" name="email_address_check" value="" style="position:absolute;left:-9999px;" tabindex="-1" />
          <input type="hidden" name="locale" value="en" />

          <!-- Honeypot: invisible to humans, bots fill it in -->
          <input type="text" name="website" value="" style="position:absolute;left:-9999px;opacity:0;height:0;" tabindex="-1" autocomplete="off" />
        </form>

        <script>
          const form = document.getElementById('sib-form') as HTMLFormElement;
          const btn = document.getElementById('signup-btn') as HTMLButtonElement;
          const successMsg = document.getElementById('success-message') as HTMLElement;

          // Record page load time for the time check
          form.dataset.loadedAt = Date.now().toString();

          form.addEventListener('submit', function(e) {
            // Honeypot check
            const honeypot = form.querySelector<HTMLInputElement>('[name="website"]');
            if (honeypot?.value) {
              e.preventDefault();
              successMsg.style.display = 'block';
              btn.textContent = 'Joined!';
              return;
            }

            // Time check: bots submit in under 3 seconds
            const loadedAt = parseInt(form.dataset.loadedAt ?? '0');
            if (Date.now() - loadedAt < 3000) {
              e.preventDefault();
              successMsg.style.display = 'block';
              btn.textContent = 'Joined!';
              return;
            }

            // Real human — POST goes to hidden iframe (no page navigation, no CORS)
            btn.disabled = true;
            btn.textContent = 'Joining…';
            setTimeout(() => {
              successMsg.style.display = 'block';
              btn.textContent = 'Joined!';
            }, 1200);
          });
        </script>

      </div>
    </div>
  </main>

  <div class="fixed top-1/4 -left-20 w-64 h-64 bg-primary-container/5 rounded-full blur-3xl -z-10"></div>
  <div class="fixed bottom-1/4 -right-20 w-96 h-96 bg-secondary-container/10 rounded-full blur-3xl -z-10"></div>
</Layout>
